{
  "name": "@clawnow/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "encrypt:secret": "node --import tsx src/scripts/encrypt-secret.ts",
    "generate:manual-sql": "node --import tsx src/scripts/generate-manual-sql.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@clawnow/core": "*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "prisma": "^6.5.0",
    "zod": "^3.24.2"
  }
}
